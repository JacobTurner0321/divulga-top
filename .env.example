JWT_SECRET=divulga-top-production-secret-2026
NODE_ENV=production

# Required on Vercel for persistent storage (affiliate IDs + products)
# Create a Blob store in Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# Optional: Upstash Redis (alternative to Blob)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: improves scraping for Shopee/Amazon (free tier: 1000 requests/month)
# https://www.scraperapi.com/
SCRAPER_API_KEY=

# Optional: Shopee Affiliate Open API (from affiliate.shopee.com.br → Open API)
# SHOPEE_AFFILIATE_APP_ID=
# SHOPEE_AFFILIATE_SECRET=

# Local dev only: path to Chrome for Shopee browser scraping
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
